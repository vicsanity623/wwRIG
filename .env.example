# WWRIG Configuration
# Copy this to .env and adjust for your setup.

# Coordinator settings
WWRIG_HOST=0.0.0.0
WWRIG_PORT=8081

# Auth token — nodes must provide this to join your pool.
# Auto-generated on first run, but you can set it here.
# WWRIG_AUTH_TOKEN=

# Node settings (when running node daemon directly)
# WWRIG_NODE_CONTRIBUTION=10
# WWRIG_NODE_HEARTBEAT=5
